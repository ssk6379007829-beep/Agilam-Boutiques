VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server-only service role, used by /api/place-order to write guest
# orders and by /api/admin-create-user to create accounts (bypasses RLS).
# REQUIRED for admin user creation — without it that endpoint fails at startup.
# NEVER expose this to the browser. SUPABASE_URL falls back to VITE_SUPABASE_URL
# if omitted.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — server-only key for transactional email (the welcome / credentials
# mail sent by /api/admin-create-user). Optional: if unset, users are still
# created and the admin console shows the temporary password to relay by hand.
# EMAIL_FROM must be a domain you've verified in Resend. APP_URL is the public
# site origin used to build the login link in the email.
RESEND_API_KEY=
EMAIL_FROM=noreply@agilam.in
APP_URL=https://your-production-domain.com

# Razorpay — server-only secrets (used by /api serverless functions)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Razorpay — publishable key id exposed to the browser (never the secret)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx

# Razorpay — webhook signing secret (server-only). Set the same value in the
# Razorpay dashboard when adding /api/razorpay-webhook for the
# payment.captured + order.paid events. Optional: the webhook is an inert no-op
# until this is configured.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Optional cross-instance rate limiting (Upstash Redis REST). When both are set,
# /api endpoints enforce a global limit; otherwise they fall back to a
# best-effort per-instance limiter.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
